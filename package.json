{
  "name": "backadb",
  "version": "1.0.0",
  "description": "A generic database backup solution with support for multiple storage providers",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "database",
    "backup",
    "mariadb",
    "docker",
    "s3",
    "google-drive",
