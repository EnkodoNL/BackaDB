# Database Connection
DB_TYPE=mariadb
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_DATABASES=all
DB_PARAMS=

# Backup Configuration
BACKUP_SCHEDULE="0 1 * * *"
BACKUP_FORMAT=sql
BACKUP_ENCRYPT=false
BACKUP_ENCRYPT_PASSWORD=
BACKUP_ON_STARTUP=false

# Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=/backups

# S3/Minio Configuration
S3_BUCKET=my-backup-bucket
S3_REGION=us-east-1
S3_ENDPOINT=https://minio.example.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_SUBDIRECTORY=backups/database

# Google Drive Configuration
GDRIVE_CLIENT_ID=your-client-id
GDRIVE_CLIENT_SECRET=your-client-secret
GDRIVE_REFRESH_TOKEN=your-refresh-token
GDRIVE_FOLDER_ID=your-folder-id

# NextCloud Configuration
NEXTCLOUD_URL=https://nextcloud.example.com
NEXTCLOUD_USERNAME=your-username
NEXTCLOUD_PASSWORD=your-password
NEXTCLOUD_FOLDER=backups

# Retention Policy
RETENTION_ENABLED=false
RETENTION_STRATEGY=count
RETENTION_COUNT=7
RETENTION_DAYS=30
RETENTION_DAILY=7
RETENTION_WEEKLY=4
RETENTION_MONTHLY=3

# Notification Configuration
NOTIFICATION_HTTP=true
NOTIFICATION_HTTP_PORT=8080
NOTIFICATION_HTTP_PATH=/health
NOTIFICATION_HTTP_TOKEN=your-random-token

# Logging
LOG_LEVEL=info